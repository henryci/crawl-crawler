{
  "name": "dcss-morgue-parser",
  "version": "1.0.0",
  "description": "A TypeScript library for parsing Dungeon Crawl Stone Soup morgue files",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dcss-morgue-parser": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "cli": "tsx src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "dcss",
    "dungeon-crawl-stone-soup",
    "morgue",
    "parser",
    "roguelike"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dcss-game-data": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

