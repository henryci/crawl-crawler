{
  "name": "dcss-loadout-optimizer",
  "version": "0.1.0",
  "description": "Equipment loadout optimizer for Dungeon Crawl Stone Soup. Given a player's inventory, finds the legal loadout that best satisfies a chosen objective (max rFire, max EV with rF+ floor, etc.).",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "dcss",
    "dungeon-crawl-stone-soup",
    "optimizer",
    "equipment",
    "loadout"
  ],
  "license": "MIT",
  "dependencies": {
    "dcss-game-data": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "dcss-morgue-parser": "workspace:*",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
