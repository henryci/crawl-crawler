{
  "name": "dcss-combo-records-parser",
  "version": "1.0.0",
  "description": "A TypeScript library for parsing DCSS top combo scores pages into structured JSON",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dcss-combo-records": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "dcss",
    "dungeon-crawl-stone-soup",
    "combo",
    "records",
    "parser",
    "roguelike",
    "scoring"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "linkedom": "^0.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

